# Runtime
APP_ENV=production
PORT=8080

# Comma-separated browser origins allowed to call HTTP APIs and open websockets.
# Example: FRONTEND_ORIGINS=https://terminal.example.com,https://www.terminal.example.com
FRONTEND_ORIGINS=https://your-frontend-domain.com

# Optional comma-separated hostnames accepted by TrustedHostMiddleware.
# Leave blank unless your platform sends a stable Host header.
ALLOWED_HOSTS=
CORS_ALLOW_CREDENTIALS=true

# Public exchange endpoints. Override only for proxies, testnets, or private gateways.
COINBASE_REST_URL=https://api.exchange.coinbase.com
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
BINANCE_REST_URL=https://data-api.binance.vision
BINANCE_WS_URL=wss://data-stream.binance.vision/ws
